VITE_WEB_APP_MODE=web
VITE_WEB_USE_SERVER_SAMPLE=false
VITE_MOBILE_SAMPLE_MODE=server-sample
# The WebRTC worktree deliberately runs beside the stable stack (8000/5173).
# Keep this here instead of relying only on the launcher environment: Vite
# resolves VITE_* values once at startup, including when launched manually.
VITE_BACKEND_ORIGIN=page-host
VITE_BACKEND_PORT=8100
