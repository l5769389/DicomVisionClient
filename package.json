{
  "name": "dicom-vision-client",
  "version": "0.1.0",
  "private": true,
  "description": "Vue3 + Electron + electron-vite + Socket.IO + Axios + Tailwind CSS DICOM viewer frontend",
  "main": "out/main/index.js",
  "type": "module",
  "build": {
    "appId": "com.dicomvision.client",
    "directories": {
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "build/icon.*",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico"
    },
    "linux": {
      "icon": "build/icon.png"
    },
    "mac": {
      "icon": "build/icon.png"
    }
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "vue-tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.node.json"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "@tailwindcss/vite": "^4.2.2",
    "@types/lodash": "^4.17.24",
    "axios": "^1.9.0",
    "lodash": "^4.17.23",
    "socket.io-client": "^4.8.1",
    "tailwindcss": "^4.2.2",
    "vite-plugin-vuetify": "^2.1.3",
    "vue": "^3.5.13",
    "vuetify": "^4.0.4"
  },
  "devDependencies": {
    "@electron-toolkit/utils": "^3.0.0",
    "@swc/core": "^1.11.24",
    "@types/node": "^22.10.2",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.6",
    "electron": "^37.0.0",
    "electron-vite": "^3.1.0",
    "jsdom": "^29.0.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vitest": "^4.1.4",
    "vue-tsc": "^2.1.10"
  }
}
