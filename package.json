{
  "name": "dicom-vision",
  "productName": "DicomVision",
  "version": "1.6.0",
  "private": true,
  "description": "Vue3 + Electron + electron-vite + Socket.IO + Axios + Tailwind CSS DICOM viewer frontend",
  "author": "DicomVision",
  "main": "out/main/index.js",
  "type": "module",
  "build": {
    "appId": "com.dicomvision.app",
    "productName": "DicomVision",
    "artifactName": "DicomVision-${version}-Setup.${ext}",
    "compression": "maximum",
    "electronLanguages": [
      "en-US",
      "zh-CN"
    ],
    "copyright": "Copyright (c) DicomVision",
    "directories": {
      "buildResources": "build",
      "output": "dist-electron"
    },
    "files": [
      "out/**/*",
      "build/icon.*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist-server/DicomVisionServer",
        "to": "server",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "executableName": "DicomVision",
      "fileAssociations": [
        {
          "ext": [
            "dcm",
            "dicom"
          ],
          "name": "DicomVision.DICOM",
          "description": "DICOM medical image",
          "role": "Viewer"
        }
      ],
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "icon": "build/icon.png"
    },
    "mac": {
      "category": "public.app-category.medical",
      "icon": "build/icon.png",
      "target": [
        "dmg",
        "zip"
      ],
      "fileAssociations": [
        {
          "ext": [
            "dcm",
            "dicom"
          ],
          "name": "DICOM medical image",
          "role": "Viewer"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "installerHeader": "build/installerHeader.bmp",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "installerSidebar": "build/installerSidebar.bmp",
      "uninstallerSidebar": "build/uninstallerSidebar.bmp",
      "include": "build/installer.nsh",
      "installerLanguages": [
        "zh_CN",
        "en_US"
      ],
      "shortcutName": "DicomVision",
      "uninstallDisplayName": "DicomVision",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "scripts": {
    "dev": "electron-vite dev",
    "dev:web": "vite --config vite.web.config.ts",
    "build": "electron-vite build",
    "build:web": "vite build --config vite.web.config.ts",
    "generate:installer-assets": "node scripts/generate-installer-assets.mjs",
    "package:mac": "node scripts/package-mac.mjs",
    "package:server": "node scripts/stage-server-bundle.mjs",
    "release:win": "powershell -ExecutionPolicy Bypass -File .\\scripts\\release-win.ps1",
    "release:mac": "node scripts/release-mac.mjs",
    "preview": "electron-vite preview",
    "preview:web": "vite preview --config vite.web.config.ts",
    "generate:api-types": "powershell -ExecutionPolicy Bypass -Command \"Push-Location ..\\DicomVisionServer; uv run python scripts\\generate_openapi_types.py --output ..\\DicomVisionClient\\src\\shared\\generated\\backendApi.ts; Pop-Location\"",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "vue-tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.node.json"
  },
  "devDependencies": {
    "@electron-toolkit/utils": "^3.0.0",
    "@mdi/js": "^7.4.47",
    "@swc/core": "^1.11.24",
    "@tailwindcss/vite": "^4.2.2",
    "@types/lodash": "^4.17.24",
    "@types/node": "^22.10.2",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.6",
    "axios": "^1.9.0",
    "electron": "^37.0.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^3.1.0",
    "jsdom": "^29.0.2",
    "lodash": "^4.17.23",
    "socket.io-client": "^4.8.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vite-plugin-vuetify": "^2.1.3",
    "vitest": "^4.1.4",
    "vue": "^3.5.13",
    "vue-tsc": "^2.1.10",
    "vuetify": "^4.0.4",
    "xstate": "^5.30.0"
  }
}
