{
  "buildCommand": "npm run build:web",
  "outputDirectory": "dist-web",
  "framework": null,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/m",
      "destination": "/index.html"
    },
    {
      "source": "/m/(.*)",
      "destination": "/index.html"
    }
  ]
}
